{
  "expo": {
    "name": "freshly",
    "slug": "freshly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "freshly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.freshly.app",
      "versionCode": 1,
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "clerkPublishableKey": "pk_test_c3Ryb25nLXN0aW5rYnVnLTQwLmNsZXJrLmFjY291bnRzLmRldiQ",
      "API_URL": "https://freshly-backend-5vmz.onrender.com/api",
      "SOCKET_URL": "https://freshly-backend-5vmz.onrender.com",
      "router": {},
      "eas": {
        "projectId": "b24b2266-7b2b-46ca-86ab-aafd22276815"
      }
    }
  }
}
