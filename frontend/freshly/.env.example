# Clerk
# Use a live key in production builds to avoid Clerk development-instance warning.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxx

# API and Socket endpoints
# Local backend (same machine):
# EXPO_PUBLIC_API_URL=http://localhost:3000/api
# EXPO_PUBLIC_SOCKET_URL=http://localhost:3000

# Android emulator backend:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api
# EXPO_PUBLIC_SOCKET_URL=http://10.0.2.2:3000

# Render production backend:
# EXPO_PUBLIC_API_URL=https://freshly-backend-5vmz.onrender.com/api
# EXPO_PUBLIC_SOCKET_URL=https://freshly-backend-5vmz.onrender.com
